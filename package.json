{
  "name": "ali-automation-tool",
  "version": "1.0.0",
  "description": "Automated test example of aliexpress.com website",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "swagger-autogen": "node swagger.js",
    "test": "mocha test/*.test.js --timeout 20000 --exit",
    "test:e2e": "mocha test/e2e/*.e2e.js --timeout 120000 --exit",
    "build": "docker build -t ali-automation-tool .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "npm audit --audit-level=moderate"
  },
  "keywords": [],
  "author": "Thiago Gonzaga",
  "license": "Apache-2.0",
  "licenses": [
    {
      "type": "Apache-2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0"
    }
  ],
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "playwright": "1.61.1",
    "process": "^0.11.10",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "chai": "^4.3.6",
    "chai-http": "^4.3.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "mocha": "^11.7.6",
    "prettier": "^3.7.4"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.7"
  }
}
